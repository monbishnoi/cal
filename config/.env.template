# Cal Gateway Configuration
# Copy this file to config/.env and fill in your values

# Required: API key for your model provider
CAL_API_KEY=

# Optional: model name and base URL
# CAL_MODEL=claude-sonnet-4-5
# CAL_BASE_URL=

# Examples:
#
# Anthropic direct:
#   CAL_API_KEY=sk-ant-...
#   CAL_MODEL=claude-sonnet-4-5
#   CAL_BASE_URL=https://api.anthropic.com
#
# AWS Bedrock:
#   CAL_API_KEY=your-bedrock-key
#   CAL_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
#   CAL_BASE_URL=https://bedrock-runtime.us-east-1.amazonaws.com
#
# LiteLLM (local proxy for OpenAI, Gemini, or other providers):
#   CAL_API_KEY=any-value
#   CAL_MODEL=openai/gpt-4o
#   CAL_BASE_URL=http://localhost:4000

# Optional: Telegram channel
# TELEGRAM_BOT_TOKEN=
# CAL_TELEGRAM_ENABLED=false
# CAL_TELEGRAM_CHAT_ID=

# Optional: iMessage (macOS only; requires imsg and Full Disk Access)
# CAL_IMESSAGE_ENABLED=false
# CAL_IMESSAGE_SENDER=+1XXXXXXXXXX
# CAL_IMESSAGE_IDENTITY=your.email@icloud.com
# CAL_IMESSAGE_CHAT_ID=
# IMSG_PATH=

# Optional: Brave Search API (for AI news)
# BRAVE_SEARCH_API_KEY=

# Server settings
# 0.0.0.0 lets same-Wi-Fi and Tailscale devices reach the PWA.
# Use 127.0.0.1 for local-machine-only access.
# CAL_HTTP_PORT=8080
# CAL_HTTP_HOST=0.0.0.0
